{
	auto_https off
	admin off
	persist_config off
}

:80 {
	root * /srv
	encode zstd gzip

	# Locale roots without trailing slash → canonical form
	redir /fr /fr/ 301
	redir /en /en/ 301

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "interest-cohort=(), geolocation=(), microphone=(), camera=()"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Frame-Options DENY
		Cross-Origin-Opener-Policy same-origin
		Cross-Origin-Resource-Policy same-site
		# CSP notes mirror public/_headers — `unsafe-inline` is required because
		# Astro emits build-time scoped <style> tags and the astro-island runtime
		# is injected as inline <script>. A nonce-based policy would require a
		# server that can rewrite each response per-request; this is a pure-static
		# host. Hash-based allowlisting would need a brittle build plugin.
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; connect-src 'self' https://cloudflareinsights.com; font-src 'self'; manifest-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
	}

	# Long-cache hashed Astro assets + self-hosted fonts (1 year, immutable)
	@immutable path /_astro/* /fonts/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	# Icons and OG image (1 week)
	@weekImages path *.svg *.png
	header @weekImages Cache-Control "public, max-age=604800"

	# PWA manifests, theme-init bootstrap (1 day)
	@daily path *.webmanifest /theme-init.js
	header @daily Cache-Control "public, max-age=86400"

	# Service worker must revalidate so updates ship promptly
	@sw path /sw.js
	header @sw Cache-Control "public, max-age=0, must-revalidate"

	# Offline fallback page (1 hour)
	@offline path /offline.html
	header @offline Cache-Control "public, max-age=3600"

	try_files {path} {path}/ {path}/index.html

	handle_errors {
		@404 expression {http.error.status_code} == 404
		rewrite @404 /404.html
		file_server
	}

	file_server
}
