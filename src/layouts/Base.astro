---
import '~/styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { swapLocaleInPath, type Locale } from '~/i18n/routes';
import { t } from '~/i18n/utils';

interface Props {
  lang: Locale;
  title: string;
  description?: string;
  pathLocalized?: { fr: string; en: string };
  isHome?: boolean;
  jsonLd?: object | object[];
}

const { lang, title, description, pathLocalized, isHome = false, jsonLd } = Astro.props;
const extraJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const fullTitle = title === t(lang, 'site.name') ? title : `${title} · ${t(lang, 'site.name')}`;
const desc = description ?? t(lang, 'site.tagline');

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const alternates = pathLocalized ?? {
  fr: swapLocaleInPath(currentPath, 'fr'),
  en: swapLocaleInPath(currentPath, 'en'),
};
const canonical = new URL(currentPath, Astro.site).toString();
const alternateFr = new URL(alternates.fr, Astro.site).toString();
const alternateEn = new URL(alternates.en, Astro.site).toString();
const ogImage = new URL(`${base}og-image.png`, Astro.site).toString();
const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_US';
const ogLocaleAlt = lang === 'fr' ? 'en_US' : 'fr_FR';
const siteName = t(lang, 'site.name');

const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
const analyticsEnabled = import.meta.env.PROD && typeof cfAnalyticsToken === 'string' && cfAnalyticsToken.length > 0;

const websiteJsonLd = isHome
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: siteName,
      url: canonical,
      description: desc,
      inLanguage: lang === 'fr' ? 'fr-FR' : 'en-US',
    }
  : null;
---
<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={desc} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}manifest-${lang}.webmanifest`} />
    <ClientRouter />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="fr" href={alternateFr} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="x-default" href={alternateFr} />
    <meta name="theme-color" content="#faf6ef" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1d19" media="(prefers-color-scheme: dark)" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    {websiteJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    )}
    {extraJsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
    {/* data-astro-rerun re-runs the theme init after view transitions so dark mode sticks. */}
    <script is:inline src={`${base}theme-init.js`} data-astro-rerun></script>
    <script src={`${base}sw-register.js`} data-base={base}></script>
    {/* Fonts are loaded via @fontsource-variable in globals.css; the emitted woff2 filenames
       are hashed by Vite, so manual <link rel="preload"> is brittle. Follow-up: Astro's
       experimental font helper (astro:assets / experimental.fonts). */}
    {analyticsEnabled && (
      <>
        <link rel="preconnect" href="https://static.cloudflareinsights.com" crossorigin />
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: cfAnalyticsToken })}
        ></script>
      </>
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded-full focus:bg-sage-700 focus:px-4 focus:py-2 focus:text-paper">
      {lang === 'fr' ? 'Aller au contenu' : 'Skip to content'}
    </a>
    <Header lang={lang} pathLocalized={pathLocalized} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
