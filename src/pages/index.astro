---
// Root → redirect to preferred language. We honour Accept-Language on build-time
// via a meta refresh that also works behind a purely static host.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const frUrl = `${base}/fr/`;
const enUrl = `${base}/en/`;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <title>Tisanerie</title>
    <meta http-equiv="refresh" content={`0; url=${frUrl}`} />
    <link rel="alternate" hreflang="fr" href={frUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={frUrl} />
    <script is:inline define:vars={{ frUrl, enUrl }}>
      try {
        var preferred = (navigator.languages && navigator.languages[0]) || navigator.language || 'fr';
        var target = preferred.toLowerCase().startsWith('en') ? enUrl : frUrl;
        window.location.replace(target);
      } catch (e) {}
    </script>
  </head>
  <body>
    <p>
      <a href={frUrl}>Tisanerie · Français</a> ·
      <a href={enUrl}>Tisanerie · English</a>
    </p>
  </body>
</html>
