---
import Base from '~/layouts/Base.astro';
---
<Base lang="fr" title="Page introuvable · 404">
  <section class="mx-auto max-w-3xl px-4 pt-24 pb-20 text-center sm:px-6">
    <p class="font-display text-8xl">🫖</p>
    <h1 class="mt-4 font-display text-5xl">404</h1>
    <p class="prose-muted mt-4">
      Cette tisane est introuvable. / This infusion is nowhere to be found.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <a class="btn-primary" href="/fr/">Accueil</a>
      <a class="btn-ghost border border-sage-200" href="/en/">Home</a>
    </div>
  </section>
</Base>
