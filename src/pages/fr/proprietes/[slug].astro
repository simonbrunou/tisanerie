---
import { getCollection } from 'astro:content';
import TaxonPage from '~/components/pages/TaxonPage.astro';
import { usedPropertyKeys } from '~/lib/taxons';

export async function getStaticPaths() {
  const herbs = await getCollection('herbs');
  return usedPropertyKeys(herbs).map((key) => ({
    params: { slug: key },
    props: { taxonKey: key },
  }));
}

const { taxonKey } = Astro.props;
---
<TaxonPage lang="fr" kind="property" taxonKey={taxonKey} />
