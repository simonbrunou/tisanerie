---
import type { Locale } from '~/i18n/routes';
import { localizedPath } from '~/i18n/routes';
import { t, type TKey } from '~/i18n/utils';
import type { HerbEntry } from '~/lib/types';

interface Props {
  lang: Locale;
  herb: HerbEntry;
  reason?: string;
  score?: number;
}

const { lang, herb, reason, score } = Astro.props;
const href = localizedPath(lang, 'herbs', herb.id);
const flavor = herb.data.flavor[lang].slice(0, 2);
const properties = (herb.data.properties ?? []).slice(0, 2);
---
<a
  href={href}
  class="group card flex h-full flex-col gap-3 p-5 transition hover:-translate-y-0.5 hover:shadow-soft focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sage-500"
>
  <div class="flex items-start justify-between gap-3">
    <span class="grid h-14 w-14 shrink-0 place-items-center rounded-2xl bg-sage-100 text-3xl dark:bg-sage-800/60" aria-hidden="true">
      {herb.data.emoji}
    </span>
    {typeof score === 'number' && score > 0 && (
      <span class="chip-amber" title="Match score">
        ★ {score}
      </span>
    )}
  </div>
  <div>
    <h3 class="font-display text-lg leading-tight">{herb.data.name[lang]}</h3>
    <p class="text-xs italic text-ink-muted">{herb.data.scientific}</p>
  </div>
  {reason && <p class="prose-muted text-sm">{reason}</p>}
  <div class="mt-auto flex flex-wrap gap-1.5">
    {flavor.map((f) => <span class="chip">{f}</span>)}
    {properties.map((p) => <span class="chip-amber">{t(lang, `property.${p}` as TKey)}</span>)}
  </div>
</a>
