---
import { getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';
import HerbCard from '~/components/HerbCard.astro';
import NeedCard from '~/components/NeedCard.astro';
import SafetyNote from '~/components/SafetyNote.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import { localizedPath, type Locale } from '~/i18n/routes';
import { t } from '~/i18n/utils';
import { herbsForNeed } from '~/lib/matcher';
import type { NeedEntry } from '~/lib/types';
import { breadcrumbList, buildNeedCrumbs } from '~/lib/jsonld';

interface Props {
  lang: Locale;
  need: NeedEntry;
}

const { lang, need } = Astro.props;
const herbsAll = await getCollection('herbs');
const ranked = herbsForNeed(herbsAll, need, 6);
const herbsById = new Map(herbsAll.map((h) => [h.id, h]));

const needsAll = await getCollection('needs');
const related = need.data.related
  .map((key) => needsAll.find((n) => n.data.benefit === key))
  .filter((n): n is NonNullable<typeof n> => Boolean(n) && n!.id !== need.id);

const warnings = Array.from(
  new Set(
    ranked
      .map((r) => herbsById.get(r.herb.id))
      .map((h) => h?.data.warnings?.[lang])
      .filter((s): s is string => Boolean(s)),
  ),
);

const pathLocalized = {
  fr: localizedPath('fr', 'needs', need.id),
  en: localizedPath('en', 'needs', need.id),
};

const crumbs = buildNeedCrumbs(lang, need);
const jsonLd = breadcrumbList(crumbs, Astro.site!);
---
<Base
  lang={lang}
  title={need.data.name[lang]}
  description={need.data.description[lang]}
  pathLocalized={pathLocalized}
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-5xl px-4 pt-16 pb-10 sm:px-6">
    <Breadcrumbs lang={lang} items={crumbs} />
    <div class="mt-4 flex items-center gap-4">
      <span class="grid h-16 w-16 place-items-center rounded-3xl bg-sage-100 text-4xl dark:bg-sage-800/60" aria-hidden="true">
        {need.data.emoji}
      </span>
      <div>
        <p class="text-sm uppercase tracking-wide text-ink-muted">{t(lang, 'home.needs.title')}</p>
        <h1 class="font-display text-4xl sm:text-5xl">{need.data.name[lang]}</h1>
      </div>
    </div>
    <p class="prose-muted mt-6 max-w-2xl text-lg">{need.data.description[lang]}</p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-14 sm:px-6">
    <h2 class="font-display text-2xl sm:text-3xl">{t(lang, 'need.herbs')}</h2>
    <ul class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {ranked.map((r) => {
        const h = herbsById.get(r.herb.id)!;
        return (
          <li>
            <HerbCard lang={lang} herb={h} score={r.score} />
          </li>
        );
      })}
    </ul>
  </section>

  {need.data.blends.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 pb-14 sm:px-6">
      <h2 class="font-display text-2xl sm:text-3xl">{t(lang, 'need.blends')}</h2>
      <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2">
        {need.data.blends.map((blend) => (
          <article class="card p-6">
            <h3 class="font-display text-xl">{blend.name[lang]}</h3>
            <ul class="mt-3 flex flex-wrap gap-2">
              {blend.herbs.map((id) => {
                const h = herbsById.get(id);
                if (!h) return null;
                return (
                  <li>
                    <a class="chip" href={localizedPath(lang, 'herbs', id)}>
                      <span aria-hidden="true" class="mr-1">{h.data.emoji}</span>
                      {h.data.name[lang]}
                    </a>
                  </li>
                );
              })}
            </ul>
            <p class="prose-muted mt-4 text-sm">{blend.instructions[lang]}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  {warnings.length > 0 && (
    <section class="mx-auto max-w-5xl px-4 pb-14 sm:px-6">
      <SafetyNote title={t(lang, 'need.safety')}>
        <ul class="list-disc space-y-1 pl-5">
          {warnings.map((w) => <li>{w}</li>)}
        </ul>
      </SafetyNote>
    </section>
  )}

  {related.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 pb-20 sm:px-6">
      <h2 class="font-display text-2xl sm:text-3xl">{t(lang, 'need.similar')}</h2>
      <ul class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {related.map((n) => (
          <li>
            <NeedCard lang={lang} need={n} />
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>
