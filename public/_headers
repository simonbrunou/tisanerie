/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=(), geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: DENY
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site
  # CSP notes:
  # - `style-src 'unsafe-inline'` stays because Astro emits build-time scoped
  #   <style> tags and CF Pages can't inject a per-request nonce.
  # - `script-src 'unsafe-inline'` is required because Astro injects the
  #   <astro-island> custom-element runtime + the Astro.load bootstrap as
  #   inline scripts, and CF Pages cannot serve per-request nonces from a
  #   static `_headers` file. Without it those scripts are blocked, the
  #   astro-island element is never upgraded, and no React island hydrates.
  # Hash-based allowlisting would need a brittle build plugin. Revisit when
  # Astro exposes a static-hash hook.
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; connect-src 'self' https://cloudflareinsights.com; font-src 'self'; manifest-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=604800

/*.png
  Cache-Control: public, max-age=604800

/*.webmanifest
  Cache-Control: public, max-age=86400

/theme-init.js
  Cache-Control: public, max-age=86400

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/offline.html
  Cache-Control: public, max-age=3600
